include gtk

&gtk|window win "GTK Test" 500 400
&gtk|vbox box 10
&gtk|hbox hb 5

&gtk|button btn "Click me!"
&gtk|button exitbtn "Exit"
&gtk|label lbl "Hello from lil"
&gtk|entry e "Type here"

&gtk|add box lbl
&gtk|add box hb
&gtk|add box e
&gtk|add hb btn
&gtk|add hb exitbtn
&gtk|add win box

&gtk|on btn clicked ev
&gtk|on exitbtn clicked exitev
&gtk|on e changed etext
&gtk|on win destroy closed

&gtk|show win

loop {
    &gtk|wait

    if ev == 1 {
        &gtk|set btn label "Clicked!"
        &gtk|set lbl label "Button was clicked"
        ev = 0
    }

    if exitev == 1 {
        &gtk|set lbl label "Goodbye!"
        &gtk|set btn sensitive false
        exitev = 0
        &math|sleep 0.5
        stop
    }

    if etext != "" {
        &gtk|set lbl label $etext
        etext = ""
    }

    if closed == 1 {
        stop
    }
}
