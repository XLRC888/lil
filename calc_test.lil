include date
include math

print "=== template strings ==="
x = 42
name = "Alice"
print `x is {x}`
print `hello {name}, x = {x}`

print "=== math hasops ==="
raw = "2 + 3"
if function math hasops $raw {
    print `{raw} has operators`
}

raw2 = "hello"
if function math hasops $raw2 {
    print "should not print"
} else {
    print `{raw2} has no operators`
}

print "=== math eval (literal string) ==="
a = function math eval "2 + 3"
print `2 + 3 = {a}`

b = function math eval "10 - 4"
c = function math eval "3 * 4"
d = function math eval "20 / 5"
e = function math eval "2 + 3 * 4"
f = function math eval "(2 + 3) * 4"
g = function math eval "10 % 3"
h = function math eval "2 * 3 + 4 * 5"
print `10 - 4 = {b}`
print `3 * 4 = {c}`
print `20 / 5 = {d}`
print `2 + 3 * 4 = {e} (should be 14)`
print `(2 + 3) * 4 = {f} (should be 20)`
print `10 % 3 = {g} (should be 1)`
print `2 * 3 + 4 * 5 = {h} (should be 26)`

print "=== full calculator demo ==="
input "> " raw
if function math hasops $raw {
    result = function math eval $raw
    print `{raw} = {result}`
} else {
    print `{raw} is not a math expression`
}

print "=== explicit literal test ==="
r2 = function math eval "100 / 4"
print `100 / 4 = {r2}`

print "done"
