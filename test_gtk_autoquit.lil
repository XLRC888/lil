include gtk

&gtk|window win "Auto Quit" 400 300
&gtk|vbox box 5
&gtk|button btn "Hello"
&gtk|label lbl "World"
&gtk|add box btn
&gtk|add box lbl
&gtk|add win box
&gtk|on win destroy closed
&gtk|on btn clicked ev

&gtk|show win
&gtk|timeout 1500

print "entering main loop"
&gtk|wait
print "back from main loop, closed=" closed " ev=" ev

if closed == 1 {
    print "window was closed"
} else {
    print "timeout fired, window still open"
}

&gtk|destroy win
&math|sleep 0.3
print "done"
