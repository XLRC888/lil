print "=== comprehensive test suite ==="

print "--- arithmetic ---"
print 1 + 2
print 10 - 4
print 3 * 4
print 20 / 5
print 10 % 3
print 1 + 2 * 3
print (1 + 2) * 3
print -5
print 10 - -3

print "--- comparison ---"
print 5 == 5
print 5 != 5
print 5 < 10
print 5 > 10
print 5 <= 5
print 5 >= 5

print "--- boolean ---"
print 1 and 1
print 1 and 0
print 0 or 1
print 0 or 0
print not 1
print not 0
print 1 and 1 and 1
print 0 or 0 or 1

print "--- strings ---"
print "hello"
print "hello" + " world"
x = "hi"
print x
print x == "hi"
print x != "bye"
print "abc" < "def"
print "z" > "a"

print "--- if/else ---"
if 1 { print "true branch" }
if 0 { print "should not print" } else { print "false branch" }

n = 5
if n > 10 {
    print "n > 10"
} else if n > 3 {
    print "n > 3"
} else {
    print "n <= 3"
}

n = 15
if n > 10 {
    print "n > 10"
} else if n > 3 {
    print "n > 3"
} else {
    print "n <= 3"
}

n = 1
if n > 10 {
    print "n > 10"
} else if n > 3 {
    print "n > 3"
} else {
    print "n <= 3"
}

print "--- while ---"
i = 1
while i <= 3 {
    print i
    i = i + 1
}

print "--- for ---"
for i = 1 to 3 {
    print i
}

print "--- nested ---"
for i = 1 to 3 {
    for j = 1 to 2 {
        print i * j
    }
}

print "--- complex ---"
sum = 0
for i = 1 to 100 {
    sum = sum + i
}
print "sum 1-100:", sum

fact = 1
n = 5
i = 1
while i <= n {
    fact = fact * i
    i = i + 1
}
print "5! =", fact

print "--- all tests passed ---"
