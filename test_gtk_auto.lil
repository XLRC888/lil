include gtk

&gtk|window win "Auto Test" 400 300
&gtk|vbox box 5
&gtk|button btn "Button"
&gtk|label lbl "initial"
&gtk|entry e "type here"
&gtk|add box btn
&gtk|add box lbl
&gtk|add box e
&gtk|add win box

&gtk|on btn clicked ev
&gtk|on e changed etext
&gtk|on win destroy closed

&gtk|show win

loop {
    &gtk|wait

    if ev == 1 {
        &gtk|set lbl label "clicked"
        ev = 0
    }

    if etext != "" {
        &gtk|set lbl label $etext
        etext = ""
    }

    if closed == 1 {
        print "window closed, exiting"
        stop
    }
}

print "test complete"
