print "--- else if still works ---"
x = 5
if x > 10 {
    print "x > 10"
} else if x > 3 {
    print "x > 3 (else if)"
} else {
    print "else"
}

print "--- elif without else ---"
y = 3
if y > 10 {
    print "y > 10"
} elif y > 2 {
    print "y > 2"
}

print "--- mixed elif with stop ---"
loop {
    print "loop start"
    z = 0
    if z == 0 {
        print "z is 0"
    } elif z == 1 {
        print "z is 1"
    } else {
        print "z is something else"
    }
    stop
}
print "after loop"

print "done"
