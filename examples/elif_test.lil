print "testing elif chains"

n = 1
if n > 10 {
    print "big"
} elif n > 5 {
    print "medium"
} elif n > 2 {
    print "small"
} else {
    print "tiny"
}

n = 3
if n > 10 {
    print "big"
} elif n > 5 {
    print "medium"
} elif n > 2 {
    print "small"
} else {
    print "tiny"
}

n = 7
if n > 10 {
    print "big"
} elif n > 5 {
    print "medium"
} elif n > 2 {
    print "small"
} else {
    print "tiny"
}

n = 15
