print "counting from 1 to 5:"
for i = 1 to 5 {
    print i
}

print "countdown from 5:"
n = 5
while n > 0 {
    print n
    n = n - 1
}

print "odd or even:"
for i = 1 to 10 {
    if i % 2 == 0 {
        print i, "is even"
    } else {
        print i, "is odd"
    }
}

print "fibonacci:"
a = 0
b = 1
print a
print b
for i = 3 to 10 {
    c = a + b
    print c
    a = b
    b = c
}

print "done!"
