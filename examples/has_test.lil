include date

print "=== has ==="
x = 42

if x has 4 { print "x has 4" } else { print "x doesnt have 4" }

x = 57
if x has 4 { print "x has 4" } else { print "x doesnt have 4" }

print "=== has with string ==="
y = "WassuP?"
if y has "w" nocase { print "y has w (nocase)" }
if y has "u" { print "y has u" }
if y has "W" { print "y has W (casesensitive)" }

print "=== has with list ==="
if y has ["u","P"] { print "y has both u and P" } else { print "missing one or both" }
if y has ["u","p"] nocase { print "y has both u and p (nocase)" } else { print "missing" }

print "=== nocase ==="
raw = "Hello World"
if raw == "hello world" nocase { print "nocase match works" }
if raw == "hello world" { print "nocase wouldnt match" } else { print "casesensitive no match (expected)" }

print "=== anywhere ==="
if raw == "ello" anywhere { print "anywhere: 'ello' found in 'Hello World'" }
if raw == "ello" { print "exact match no" } else { print "exact match no (expected)" }

print "=== nocase + anywhere ==="
if raw == "ELLO" nocase anywhere { print "nocase+anywhere: 'ELLO' found in 'Hello World'" }

print "=== word ==="
s = "wassup hello"
if s == "hello" word { print "word: 'hello' found as word" }
if s == "ello" word { print "word: should not match" } else { print "word: 'ello' not a word (expected)" }

print "=== word with nocase ==="
t = "HELLO world"
if t == "hello" nocase word { print "nocase word works" }

print "=== all tests done ==="
