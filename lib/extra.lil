$range(start end) { i = start; loop { if i >= end { stop }; print i; i = i + 1 } }
$sum(list) { total = 0; i = 0; loop { if i >= &list|len list { stop }; total = total + &list|at list i; i = i + 1 }; total }
$map(list fn) { res = &list|new; i = 0; loop { if i >= &list|len list { stop }; val = $fn(&list|at list i); &list|push res val; i = i + 1 }; res }
$filter(list fn) { res = &list|new; i = 0; loop { if i >= &list|len list { stop }; val = &list|at list i; if $fn(val) { &list|push res val }; i = i + 1 }; res }
$range_list(start end) { res = &list|new; i = start; loop { if i >= end { stop }; &list|push res i; i = i + 1 }; res }
