#range(start end) { i = start; loop { if i >= end { stop }; print i; i = i + 1 } }
#sum(list) { total = 0; i = 0; loop { if i >= len@list list { stop }; total = total + at@list list i; i = i + 1 }; total }
#range_list(start end) { res = []; i = start; loop { if i >= end { stop }; push@list res i; i = i + 1 }; res }
