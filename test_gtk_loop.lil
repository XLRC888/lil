include gtk

&gtk|window win "Loop Test" 400 300
&gtk|vbox box 5
&gtk|button btn "Test"
&gtk|label lbl "waiting..."
&gtk|entry e "type here"
&gtk|add box btn
&gtk|add box lbl
&gtk|add box e
&gtk|add win box

&gtk|on btn clicked ev
&gtk|on e changed etext
&gtk|on win destroy closed

&gtk|show win
&gtk|timeout 500

&gtk|wait

if ev == 1 {
    print "button was clicked!"
}

if etext != "" {
    print "entry text: " etext
    &gtk|set lbl label $etext
}

if closed == 1 {
    print "window was closed"
}

if ev == "" && etext == "" && closed == "" {
    print "timeout - no events"
}

&gtk|destroy win
&math|sleep 0.2
print "done"
